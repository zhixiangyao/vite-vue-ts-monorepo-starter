{
  "name": "vite-vue-ts-monorepo-starter",
  "type": "module",
  "version": "0.1.0",
  "author": "zhixiangyao <blueskyzx@icloud.com> <https://github.com/zhixiangyao>",
  "license": "MIT",
  "homepage": "https://github.com/zhixiangyao/vite-vue-ts-monorepo-starter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhixiangyao/vite-vue-ts-monorepo-starter.git"
  },
  "packageManager": "pnpm@11.0.6",
  "engines": {
    "node": ">=25.9.0",
    "pnpm": ">=11.0.6"
  },
  "scripts": {
    "postinstall": "simple-git-hooks",
    "------------- TURBO -------------": "",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "------------- LINT -------------": "",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "lint:css": "stylelint \"./**/*.{vue,css}\" --cache --cache-location node_modules/.cache/stylelint/",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "postcss-html": "catalog:",
    "simple-git-hooks": "catalog:",
    "stylelint": "catalog:",
    "stylelint-config-recess-order": "catalog:",
    "stylelint-config-recommended-vue": "catalog:",
    "stylelint-config-standard": "catalog:",
    "stylelint-order": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "**/*.{js,cjs,mjs,jsx,ts,mts,tsx,vue}": [
      "pnpm lint:check"
    ],
    "**/*.{js,cjs,mjs,jsx,ts,mts,tsx,vue,html,md,json,css,yaml,yml}": [
      "pnpm fmt:check"
    ],
    "**/*.{vue,css}": [
      "stylelint --cache --cache-location node_modules/.cache/stylelint/"
    ]
  }
}
